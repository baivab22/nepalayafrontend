modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["npm", "run", "build", "--prefix", "client"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "NODEJS"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
