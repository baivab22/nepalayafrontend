{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx --env-file-if-exists=.env.local ./src/index.ts",
    "build": "tsx ./build.ts",
    "start": "NODE_ENV=production node ./dist/index.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "express": "^5",
    "mongoose": "8.19.3",
    "multer": "^2.1.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.3",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.2",
    "tsx": "^4.21.0"
  }
}
