# ========================================
# MONGODB ATLAS CONFIGURATION
# ========================================
# Replace with your MongoDB Atlas URI from: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nepalaya?retryWrites=true&w=majority
MONGODB_DB_NAME=nepalaya

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=8000
NODE_ENV=production

# ========================================
# CORS CONFIGURATION
# ========================================
# Frontend URL for CORS (adjust for production)
FRONTEND_URL=https://yourdomain.com

# ========================================
# FILE UPLOAD CONFIGURATION
# ========================================
# Maximum upload size in MB
MAX_UPLOAD_SIZE=50
UPLOAD_DIR=./uploads

# ========================================
# ADMIN CREDENTIALS (Change these!)
# ========================================
ADMIN_PASSWORD=admin@nepalaya2025
